{
  "name": "agent-booster-pack-github",
  "version": "0.0.0",
  "private": true,
  "description": "GitHub-installable Agent Booster Pack package for Pi.",
  "packageManager": "pnpm@10.33.0",
  "type": "module",
  "pi": {
    "extensions": [
      "./agent-booster-pack/src/index.ts"
    ],
    "skills": [
      "./agent-booster-pack/skills"
    ]
  },
  "scripts": {
    "check:links": "node scripts/validate-markdown-links.mjs",
    "test": "vitest run tests"
  },
  "files": [
    "agent-booster-pack/src",
    "agent-booster-pack/extensions",
    "agent-booster-pack/skills",
    "agent-booster-pack/README.md",
    "agent-booster-pack/LICENSE",
    "README.md",
    "LICENSE"
  ],
  "devDependencies": {
    "remark-cli": "^12.0.1",
    "remark-validate-links": "^13.1.0",
    "vitest": "^3.2.1"
  }
}
