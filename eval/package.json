{
  "name": "agent-booster-pack-eval",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "eval": "do-eval tui --project .",
    "eval:list": "do-eval list --project .",
    "eval:trial": "do-eval trial --project .",
    "eval:regression": "do-eval regression allSkills --project .",
    "eval:bench": "do-eval bench allSkills --project .",
    "eval:web": "do-eval ui --project .",
    "bench": "npm run eval:bench",
    "bench:smoke": "do-eval bench smoke --project .",
    "bench:core": "do-eval bench core --project .",
    "bench:routing": "do-eval bench routing --project .",
    "bench:large": "do-eval bench largeProject --project .",
    "bench:all": "do-eval bench allSkills --project .",
    "regression": "npm run eval:regression",
    "regression:smoke": "do-eval regression smoke --project .",
    "regression:core": "do-eval regression core --project .",
    "regression:routing": "do-eval regression routing --project .",
    "regression:large": "do-eval regression largeProject --project .",
    "regression:all": "do-eval regression allSkills --project .",
    "regression:check": "do-eval regression regressionCheck --project .",
    "trial": "npm run eval:trial --",
    "list": "npm run eval:list",
    "view": "npm run eval:web",
    "test": "vitest run test",
    "typecheck": "tsc --noEmit",
    "tui": "npm run eval"
  },
  "dependencies": {
    "do-eval": "file:../../pi-do-eval"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "typescript": "^5.7.0",
    "vitest": "^3.2.1"
  }
}
